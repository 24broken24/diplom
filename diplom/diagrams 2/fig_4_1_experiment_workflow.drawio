        <mxCell id="cap" value="&lt;b&gt;Рис. 4.1. Методика контрольного эксперимента: от наборов данных до сводки качества&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Один прогон комплекса; пороги benchmarkThresholds задаются в gp_settings.json&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="16" width="820" height="44" as="geometry" />
        </mxCell>
