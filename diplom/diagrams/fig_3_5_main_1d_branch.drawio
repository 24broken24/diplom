        <mxCell id="cap" value="&lt;b&gt;Рис. 3.5. Ветвь Main: одномерная регрессия (два столбца x, y)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Фрагмент Program.Main после открытия .xlsx при colCount ≤ 2&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
