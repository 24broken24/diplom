        <mxCell id="1" parent="0" />
        <mxCell id="cap" value="&lt;b&gt;Рис. 1.3 (схема). Турнирный отбор родителя&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;k - размер турнира; из k случайных особей выбирают ту, у которой меньше всего fitness (минимизируемая целевая функция).&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="760" height="56" as="geometry" />
        </mxCell>
        <mxCell id="instr" value="1. Случайно выбрать &lt;b&gt;k&lt;/b&gt; особей из популяции&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Ниже пример при k = 3.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="95" width="440" height="52" as="geometry" />
