        <mxCell id="t1" value="участник A&lt;br&gt;&lt;b&gt;fitness 12,4&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
